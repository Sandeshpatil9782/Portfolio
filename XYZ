

/* Contact */
.contact-container{
  max-width:900px;
  margin:auto;
  text-align:center;
}

.contact-info p{
  margin:10px 0;
}

/* Center button */
.contact-form{
  margin-top:30px;
  display:flex;
  justify-content:center;
}

/* Button style */
.contact-form button{
  padding:12px 30px;
  border:none;
  background:#38bdf8;
  color:#0f172a;
  font-weight:bold;
  border-radius:30px;
  cursor:pointer;
  transition:0.3s;
}

.contact-form button:hover{
  background:white;
  transform:scale(1.05);
}
